# Piilosana — environment variables
# Copy this file to .env and fill in real values for local development.
# In production (Railway), set these in the project's Variables tab.

# ============================================================================
# Server
# ============================================================================

# Port the Express + Socket.IO server listens on.
# Railway injects PORT automatically; defaults to 3001 locally.
PORT=3001

# ============================================================================
# Database
# ============================================================================

# Postgres connection URL (preferred for production — survives restarts,
# enables zero-downtime deploys).
# Format: postgresql://user:password@host:5432/dbname
# When set, the app uses Postgres. When unset, falls back to in-process
# sql.js (DB lost on restart unless persisted to /data volume).
# Add a Postgres add-on on Railway and copy the connection URL here.
DATABASE_URL=

# Fallback only when DATABASE_URL is not set: directory for sql.js DB file.
# Defaults to /data on Railway, ./repo-root locally.
DB_PATH=/data

# ============================================================================
# Authentication
# ============================================================================

# Google OAuth client ID for "Sign in with Google" (optional).
# Without this, only username/password auth is available.
# Create one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ============================================================================
# Email — used for password reset
# ============================================================================

# Resend.com API key (optional). Without this, password reset is disabled.
RESEND_API_KEY=

# Sender address for system emails. Must be from a verified domain on Resend.
RESEND_FROM=Piilosana <onboarding@resend.dev>
